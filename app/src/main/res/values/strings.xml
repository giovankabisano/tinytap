    <!-- Education -->
    <string name="education_title">Tentang Gerakan Bayi</string>
    <string name="education_when_to_contact">Kapan Harus Menghubungi Tenaga Medis</string>
    <string name="education_intro">Setiap kehamilan berbeda. Yang terpenting adalah kamu mengenali pola gerakan normal bayimu sendiri dan menyadari jika ada perubahan.</string>
    <string name="education_movement_info">Bayi biasanya mulai terasa bergerak sekitar usia kehamilan 18–24 minggu. Seiring bertambahnya usia kehamilan, kamu akan makin mengenali pola dan waktu aktif bayimu.</string>
    <string name="education_kick_count_info">Penghitungan tendangan paling bermakna di trimester ke-3 (sekitar 28 minggu ke atas). Umumnya, bayi bergerak setidaknya 10 kali dalam 2 jam — namun ini bukan patokan mutlak.</string>
    <string name="education_contact_title">Segera hubungi bidan atau rumah sakit jika:</string>
    <string name="education_contact_1">Kamu merasa gerakan bayi berkurang atau berbeda dari pola biasanya</string>
    <string name="education_contact_2">Kamu tidak merasakan gerakan bayi sama sekali</string>
    <string name="education_contact_3">Kamu memiliki kekhawatiran apa pun tentang kondisi bayimu</string>
    <string name="education_contact_footer">Jangan menunggu — layanan bidan dan rumah sakit tersedia 24 jam. Kalau ragu, hubungi tenaga medis.</string>
    <string name="education_call_contact">Hubungi Tenaga Medis</string>
    <string name="education_no_contact">Belum ada nomor kontak tersimpan. Kamu bisa menambahkannya di Pengaturan.</string>
    <string name="education_disclaimer">Informasi ini bersifat umum berdasarkan panduan RCOG dan ACOG, disajikan dalam bahasa sederhana. Ini bukan pengganti konsultasi medis.</string>

